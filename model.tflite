298192: TensorSpec(shape=(), dtype=tf.resource, name=None)\n","  138409877299344: TensorSpec(shape=(), dtype=tf.resource, name=None)\n","  138409877297424: TensorSpec(shape=(), dtype=tf.resource, name=None)\n","  138409877300112: TensorSpec(shape=(), dtype=tf.resource, name=None)\n","  138409877301072: TensorSpec(shape=(), dtype=tf.resource, name=None)\n","  138409877300304: TensorSpec(shape=(), dtype=tf.resource, name=None)\n","Success! Model.tflite ready aayiduchi. Check the folder.\n"]}],"source":["import tensorflow as tf\n","\n","# 1. Load your H5 model\n","model = tf.keras.models.load_model('/content/drive/MyDrive/Colab_Notebooks/plantdisease.ipynb.h5')\n","\n","# 2. Convert to TFLite (Compression)\n","converter = tf.lite.TFLiteConverter.from_keras_model(model)\n","converter.optimizations = [tf.lite.Optimize.DEFAULT] # Size-ah kuraikum\n","tflite_model = converter.convert()\n","\n","# 3. Save it\n","with open('model.tflite', 'wb') as f:\n","    f.write(tflite_model)\n","\n","print(\"Success! Model.tflite ready aayiduchi. Check the folder.\")"]}]}